NETNOD_API_URL=https://primarydnsapi.netnod.se
NETNOD_NDSAPI_URL=https://dnsnodeapi.netnod.se
NETNOD_API_TOKEN=your-token-here
SERVER_HOST=localhost
SERVER_PORT=3000
SESSION_SECRET=change-this-to-a-random-string

# sqlite options
DB_DRIVER=sqlite
DB_PATH=data/zonemeister.db

# postgres options
#DB_DRIVER=postgres
#DB_URL=postgres://user:password@localhost:5432/zonemeister?sslmode=disable

LOG_LEVEL=info
# Set to false for local development without TLS, otherwise true
SECURE_COOKIES=false

# SMTP (optional — enables password reset via email)
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=noreply@example.com
#BASE_URL=https://dns.example.com
